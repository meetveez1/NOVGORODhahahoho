        "jsCode": "const rows   = $input.all().map(i => i.json);\nconst chatId = $('Разобрать сообщение1').item.json.chatId;\nlet text;\nif (!rows.length || !rows[0].file_name) {\n  text = '📚 Книги ещё не загружены.\\n\\nОтправь .txt файл прямо в чат, чтобы добавить книгу.';\n} else {\n  const list = rows.map((r, i) =>\n    `${i+1}. 📗 *${r.file_name}*\\n    ${r.chunk_count} фрагм. · ${Math.round(r.size_bytes/1024)} КБ`\n  ).join('\\n\\n');\n  text = `📚 *Загруженные книги (${rows.length}):*\\n\\n${list}\\n\\nЧтобы найти — /search запрос`;\n}\nreturn [{ json: { chatId, text } }];"
