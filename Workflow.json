        "jsCode": "const text = $json.data?.text || \"\"; // Текст сообщения пользователя\n\n// 1. Ищем главу (Глава 5, Гл. 4, 3 глава, в пятой главе)\nconst chapterMatch = text.match(/(?:глава|гл\\.?|гл|в|главе)\\s*(\\d+|[IVXLCDM]+)|(\\d+|[IVXLCDM]+)\\s*(?:глава|главе|гл\\.?)/i);\n\n// 2. Ищем том (Том 2, Т. 1, 3 том)\nconst volumeMatch = text.match(/(?:том|т\\.?)\\s*(\\d+|[IVXLCDM]+)|(\\d+|[IVXLCDM]+)\\s*(?:том|т\\.?)/i);\n\n// Функция для перевода римских цифр (из нашего прошлого кода)\nfunction romanToArab(roman) {\n  if (!roman) return null;\n  if (!isNaN(roman)) return parseInt(roman);\n  const lookup = { I: 1, V: 5, X: 10, L: 50, C: 100, D: 500, M: 1000 };\n  let arab = 0;\n  let i = roman.toUpperCase().length;\n  while (i--) {\n    if (lookup[roman[i]] < lookup[roman[i + 1]]) {\n      arab -= lookup[roman[i]];\n    } else {\n      arab += lookup[roman[i]];\n    }\n  }\n  return arab;\n}\n\n// Извлекаем чистые числа\nconst chapter = chapterMatch ? romanToArab(chapterMatch[1] || chapterMatch[2]) : null;\nconst volume = volumeMatch ? romanToArab(volumeMatch[1] || volumeMatch[2]) : null;\n\nreturn {\n  query: text,\n  filter_chapter: chapter,\n  filter_volume: volume,\n  has_filter: !!(chapter || volume)\n};\n"
      },
