    {
      "parameters": {
        "jsCode": "const rows   = $input.first().json;\nconst query  = $('Разобрать сообщение1').item.json.query;\nconst mode   = $('Разобрать сообщение1').item.json.mode;\nconst chatId = $('Разобрать сообщение1').item.json.chatId;\n\nconst results = Array.isArray(rows) ? rows : [];\n\nif (!results.length) {\n  return [{ json: { chatId, noResults: true, query, mode } }];\n}\n\nconst context = results.map((r, i) => [\n  `[Фрагмент ${i+1}] | Сходство: ${(r.similarity * 100).toFixed(0)}%`,\n  `Книга: «${r.book_name}» | Раздел: ${r.chapter} | Строки: ${r.line_start}–${r.line_end}`,\n  '',\n  r.content\n].join('\\n')).join('\\n\\n---\\n\\n');\n\nconst systemPrompt = mode === 'qa'\n  ? 'Ты помощник, который отвечает на вопросы СТРОГО на основе предоставленных фрагментов книг. Давай подробный ответ. В конце обязательно приведи 2-3 прямые цитаты из текста в кавычках с указанием книги. Если ответа нет в предоставленных фрагментах — честно сообщи об этом. Отвечай на русском языке.'\n  : 'Ты помощник для поиска по книгам. Из предоставленных фрагментов выбери 3-5 наиболее подходящих под запрос. Для каждого: укажи книгу и место в тексте, приведи краткую цитату, объясни 1 предложением почему фрагмент подходит. Если ни один фрагмент не подходит под запрос — честно скажи об этом. Отвечай на русском языке.';\n\nconst userPrompt = `${mode === 'qa' ? 'Вопрос' : 'Запрос'}: «${query}»\\n\\nФрагменты из книг:\\n\\n${context}`;\n\nreturn [{ json: { chatId, mode, query, systemPrompt, userPrompt, noResults: false } }];"
      },
