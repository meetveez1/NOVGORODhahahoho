      "parameters": {
        "jsCode": "const input = $input.first();\nconst fullText = input.json.text || \"\";\nconst fileName = $('Send message and wait for response2').first().json.data['Загрузите книгу'][0].filename.replace('.txt', '');\n\nfunction romanToArab(roman) {\n  if (!isNaN(roman)) return parseInt(roman);\n  const lookup = { I: 1, V: 5, X: 10, L: 50, C: 100, D: 500, M: 1000 };\n  let arab = 0;\n  let i = roman.toUpperCase().length;\n  while (i--) {\n    if (lookup[roman[i]] < lookup[roman[i + 1]]) {\n      arab -= lookup[roman[i]];\n    } else {\n      arab += lookup[roman[i]];\n    }\n  }\n  return arab;\n}\n\n// Ваша рабочая регулярка для поиска глав\nconst chapterRegex = /(?:\\n|^)(?:Глава\\s+)?([IVXLCDM]+|[0-9]+)(?:\\.|\\s)*(?:\\n|\\r|$)/gi;\n\nconst parts = fullText.split(chapterRegex);\nlet results = [];\n\n// Функция для очистки текста (шлифовка \\n и пробелов)\nfunction cleanText(t) {\n  return t.replace(/[\\r\\n]+/g, '\\n').replace(/[ \\t]+/g, ' ').trim();\n}\n\n// ЕСЛИ ГЛАВЫ НАЙДЕНЫ (parts.length > 1)\nif (parts.length > 1) {\n  for (let i = 1; i < parts.length; i += 2) {\n    const originalChapter = parts[i].trim();\n    const chapterNumber = romanToArab(originalChapter.toUpperCase());\n    let chapterContent = parts[i + 1] ? parts[i + 1] : \"\";\n    \n    chapterContent = cleanText(chapterContent);\n\n    // Фильтр: длина > 150 символов и наличие букв (убираем сноски)\n    if (chapterContent.length > 150 && /[а-яА-Яa-zA-Z]/.test(chapterContent)) {\n      results.push({\n        json: {\n          text: `Глава ${chapterNumber}\\n${chapterContent}`,\n          metadata: { chapter: chapterNumber, book: fileName }\n        }\n      });\n    }\n  }\n}\n\n// ЕСЛИ ГЛАВЫ НЕ НАЙДЕНЫ ИЛИ ВСЕ БЫЛИ ОТСЕЯНЫ КАК МАЛЕНЬКИЕ\nif (results.length === 0) {\n  const polishedText = cleanText(fullText);\n\n  if (polishedText.length > 150 && /[а-яА-Яa-zA-Z]/.test(polishedText)) {\n    results.push({\n      json: {\n        text: polishedText,\n        metadata: { chapter: 1, book: fileName }\n      }\n    });\n  }\n}\n\nreturn results;\n"
      },
