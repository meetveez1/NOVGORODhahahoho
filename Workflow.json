      ]
    },
    {
      "parameters": {
        "jsCode": "// 1. Получаем текст и имя файла (пути из вашего рабочего кода)\nconst rawText = $input.first().json.text || \"\";\n// Обратите внимание: путь к имени файла должен точно соответствовать структуре в n8n\nconst fileName = $('Send message and wait for response2').first().json.data['Загрузите книгу'][0].filename || 'book.txt';\n\n// Проверка на пустоту\nif (!rawText || rawText.length < 10) {\n  throw new Error('Текст не найден. Убедитесь, что файл передан корректно.');\n}\n\nconst CHUNK_SIZE = 1200; \nconst OVERLAP = 200;\n// Регулярка для определения глав (улучшенная версия)\nconst chapterRe = /^\\s*(annotation|глава|часть|том|chapter|раздел)\\s*.*|^\\s*[IVXLCDM]+\\s*$/i;\n\nconst lines = rawText.split('\\n');\nlet currentChapter = \"Начало / Аннотация\";\nlet buffer = \"\";\nlet lineStart = 1;\nconst chunks = [];\n\nfor (let i = 0; i < lines.length; i++) {\n  const line = lines[i].trim();\n  if (!line) continue;\n\n  // Если встретили заголовок главы (ограничение длины строки, чтобы не принять обычный текст за главу)\n  if (chapterRe.test(line) && line.length < 60) {\n    if (buffer.trim().length > 5) {\n      chunks.push({ \n        chapter: currentChapter, \n        lineStart, \n        lineEnd: i, \n        content: buffer.trim() \n      });\n      buffer = \"\";\n    }\n    currentChapter = line;\n    lineStart = i + 1;\n  }\n\n  buffer += line + \" \";\n\n  // Нарезка по размеру (с учетом перекрытия OVERLAP)\n  if (buffer.length >= CHUNK_SIZE) {\n    chunks.push({ \n      chapter: currentChapter, \n      lineStart, \n      lineEnd: i + 1, \n      content: buffer.trim() \n    });\n    // Оставляем «хвост» для контекста следующего чанка\n    buffer = buffer.slice(-OVERLAP);\n    lineStart = i + 1;\n  }\n}\n\n// Добавляем последний кусок текста\nif (buffer.trim().length > 5) {\n  chunks.push({ \n    chapter: currentChapter, \n    lineStart, \n    lineEnd: lines.length, \n    content: buffer.trim() \n  });\n}\n\n// Формируем выходные данные как в первом примере\nreturn [{ \n  json: { \n    chunks: chunks, \n    fileName: fileName,\n    totalChunks: chunks.length,\n    sizeBytes: rawText.length\n  } \n}];"
      },
